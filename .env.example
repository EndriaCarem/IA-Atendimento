NODE_ENV=development
PORT=3333

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=
# Optional: Supabase Personal Access Token for running automated schema setup scripts.

AI_PROVIDER=gemini

# Gemini (default provider)
GEMINI_API_KEY=your-google-ai-studio-key
# Suggested starting model for free tier accounts
GEMINI_MODEL=gemini-2.0-flash

# Ollama (100% local/free provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional: enable outgoing WhatsApp messages (self-hosted Evolution)
# Local dev example: http://localhost:8080
# Production: use your public Evolution server URL (never localhost).
EVOLUTION_API_URL=
# Required when EVOLUTION_API_URL is set (official Evolution docs use apikey auth)
EVOLUTION_API_KEY=
# Must match AUTHENTICATION_API_KEY in the Evolution server .env

# Optional: protect webhook endpoint with shared secret
EVOLUTION_WEBHOOK_SECRET=

# Table names
TABLE_CLINICS=clinics
TABLE_WHATSAPP_INSTANCES=whatsapp_instances
TABLE_PATIENTS=patients
TABLE_APPOINTMENTS=appointments

# Column names
COL_INSTANCE_NAME=instance_name
COL_INSTANCE_CLINIC_ID=clinic_id
COL_CLINIC_PROMPT=custom_prompt
COL_PATIENT_CLINIC_ID=clinic_id
COL_PATIENT_PHONE=phone
COL_APPOINTMENT_CLINIC_ID=clinic_id
COL_APPOINTMENT_PATIENT_ID=patient_id
COL_APPOINTMENT_DATETIME=scheduled_at
COL_APPOINTMENT_STATUS=status
COL_APPOINTMENT_NOTES=notes

DEFAULT_TIMEZONE=America/Sao_Paulo

# Onboarding helper (scripts/evolution-onboarding.js)
ONBOARD_INSTANCE_NAME=
# Optional now. If empty, onboarding creates/connects instance and you bind later.
# If Evolution runs in Docker, use host.docker.internal for webhook URL.
ONBOARD_CLINIC_ID=
ONBOARD_WEBHOOK_URL=http://host.docker.internal:3333/webhooks/evolution
ONBOARD_INSTANCE_TOKEN=
ONBOARD_NUMBER=
ONBOARD_INTEGRATION=WHATSAPP-BAILEYS

# Late binding helper (scripts/bind-instance-clinic.js)
BIND_INSTANCE_NAME=
BIND_CLINIC_ID=
